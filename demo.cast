[0.000, "o", "  \u001b[31mEMAIL_ADDRESS   \u001b[0m \"\u001b[1mjane@acme.com\u001b[0m\"  \u001b[2m[10:23]\u001b[0m  confidence: 1.00\r\n  \u001b[33mPHONE_NUMBER    \u001b[0m \"\u001b[1m555-867-5309\u001b[0m\"  \u001b[2m[25:37]\u001b[0m  confidence: 0.40\r\n\r\n\u001b[2mOutput:\u001b[0m \u001b[32m[REDACTED_PERSON], [REDACTED_EMAIL_ADDRESS], [REDACTED_PHONE_NUMBER]\u001b[0m\r\n"]
