[0.000, "o", "\r\n  \u001b[36m\u001b[1mpii-safe\u001b[0m \u001b[2mv0.1.0\u001b[0m\r\n  \u001b[2mPrivacy middleware for AI agent workflows\u001b[0m\r\n  \u001b[2mGSoC 2026 — C2SI PII-Safe Proof of Concept\u001b[0m\r\n\r\n"]
[3.008, "o", "  \u001b[2mDetects PII using presidio + spaCy NER (20+ entity types),\u001b[0m\r\n  \u001b[2mapplies policy-driven sanitization (redact / pseudonymize / allowlist),\u001b[0m\r\n  \u001b[2mand exposes everything as MCP tools for AI agents.\u001b[0m\r\n\r\n"]
[3.007, "o", "  \u001b[33m\u001b[1mDemo 1:\u001b[0m \u001b[2mScan text with default policy (redact all, pseudonymize names)\u001b[0m\r\n\r\n"]
[2.355, "o", "\r\n\u001b[1mPII-Safe v0.1.0\u001b[0m\r\n\r\n\u001b[2mInput:\u001b[0m  John Smith's email is john@example.com and his IP is 192.168.1.1\r\n\r\nDetected \u001b[1m4\u001b[0m PII entities:\r\n  \u001b[31mPERSON          \u001b[0m \"\u001b[1mJohn Smith's\u001b[0m\"  \u001b[2m[0:12]\u001b[0m  confidence: 0.85\r\n  \u001b[31mEMAIL_ADDRESS   \u001b[0m \"\u001b[1mjohn@example.com\u001b[0m\"  \u001b[2m[22:38]\u001b[0m  confidence: 1.00\r\n  \u001b[31mORGANIZATION    \u001b[0m \"\u001b[1mIP\u001b[0m\"  \u001b[2m[47:49]\u001b[0m  confidence: 0.85\r\n  \u001b[31mIP_ADDRESS      \u001b[0m \"\u001b[1m192.168.1.1\u001b[0m\"  \u001b[2m[53:64]\u001b[0m  confidence: 0.95\r\n\r\n\u001b[2mOutput:\u001b[0m \u001b[32mJames Wilson email is [REDACTED_EMAIL_ADDRESS] and his [REDACTED_ORGANIZATION] is [REDACTED_IP_ADDRESS]\u001b[0m\r\n\r\nPrivacy Risk Score: \u001b[31m0.60 (HIGH)\u001b[0m\r\n  4 entities detected, 4 sanitized, 0 leaked\r\n"]
[0.000, "o", "\r\n"]
[4.075, "o", "  \u001b[33m\u001b[1mDemo 2:\u001b[0m \u001b[2mStrict policy — redact everything including names\u001b[0m\r\n\r\n"]
